# .env.example - 环境变量配置模板
# 复制为 .env 并填入实际值

# LLM 配置（用于 --use-llm-writer 模式，写作 Agent）
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o
LLM_API_BASE=https://api.openai.com/v1

# 审稿 Agent 配置（独立于写作 LLM，避免自己写自己打分）
# 如果不配置，审稿 Agent 将 fallback 到写作 LLM 的配置
# REVIEW_LLM_API_KEY=your-review-api-key
# REVIEW_LLM_MODEL=gpt-4o
# REVIEW_LLM_API_BASE=https://api.openai.com/v1

# 日志分析 Agent 配置（独立于写作/审稿 LLM，用于分析流水线失败日志）
# 当已知坑位规则未匹配时，自动调用 LLM 分析错误并给出沉淀建议
# 如果不配置，将 fallback 到 LLM_*；都不可用则跳过 LLM 分析
# LOG_ANALYZER_LLM_API_KEY=your-log-analyzer-api-key
# LOG_ANALYZER_LLM_MODEL=gpt-4o-mini
# LOG_ANALYZER_LLM_API_BASE=https://api.openai.com/v1

# 或者使用 OpenAI 标准变量
# OPENAI_API_KEY=your-api-key-here

# Python 编码（Windows 下建议设置）
PYTHONIOENCODING=utf-8

# Windows 微信前台接管（需要真实操作微信时开启）
# visual = 自动恢复已有微信主窗口 -> 截图预检 -> 窗口相对坐标操作
# 不自动点击任务栏/托盘微信图标，不默认启动新的微信实例，不使用全局 Ctrl+W 清理窗口。
WECHAT_WINDOWS_FOREGROUND_STRATEGY=visual
WECHAT_WINDOWS_AUTO_REVEAL=1
# WECHAT_WINDOWS_AUTO_REVEAL_USE_DEEPLINK=1
# WECHAT_WINDOWS_AUTO_REVEAL_ALLOW_LAUNCH=1
WECHAT_WINDOWS_VISUAL_MAXIMIZE_EACH_STEP=0
WECHAT_WINDOWS_REQUIRE_MAXIMIZED=1
WECHAT_WINDOWS_AFTER_AUTO_REVEAL_WAIT=0.7
WECHAT_WINDOWS_AFTER_RESTORE_WAIT=0.45
WECHAT_WINDOWS_AFTER_INITIAL_MAXIMIZE_WAIT=0.35
WECHAT_WINDOWS_REQUIRE_VISUAL_PREFLIGHT=1
WECHAT_FOREGROUND_ASSUME_READY=1
WECHAT_FOREGROUND_MAX_ARTICLES=10
WECHAT_FOREGROUND_REQUIRE_DATE_VERIFY=1
